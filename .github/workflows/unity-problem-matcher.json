{
  "problemMatcher": [
    {
      "owner": "unity-error",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^(.*\\.cs)\\((\\d+),(\\d+)\\):\\s+error\\s+(.+?):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "code": 4,
          "message": 5
        }
      ]
    },
    {
      "owner": "unity-warning",
      "severity": "warning",
      "pattern": [
        {
          "regexp": "^(.*\\.cs)\\((\\d+),(\\d+)\\):\\s+warning\\s+(.+?):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "code": 4,
          "message": 5
        }
      ]
    }
  ]
}
